      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { ok: true } }}",
        "options": {}
      },
      "id": "respond-ok",
      "name": "Responder webhook",
      "type": "n8n-nodes-base.respondToWebhook",
