        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{JSON.stringify({ leadId: $('Gerar resposta IA').item.json.lead.id, status: $('Gerar resposta IA').item.json.leadStatus, interest: $('Gerar resposta IA').item.json.detectedInterest, shouldScheduleFollowUp: true, followUpMinutes: $('Gerar resposta IA').item.json.followUpMinutes })}}",
        "options": {}
      },
      "id": "update-lead",
      "name": "Atualizar lead/follow-up",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2360,
