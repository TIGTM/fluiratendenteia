{
  "name": "Fluir Atendente IA - Inbound WhatsApp",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "atendente-ia/inbound",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-inbound",
      "name": "Webhook WAHA",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "webhookId": "fluir-atendente-ia-inbound"
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst payload = body.payload || body;\nconst from = payload.from || payload.chatId || payload.author || '';\nconst session = body.session || payload.session || payload.sessionName || $env.WAHA_SESSION || 'default';\nconst message = payload.body || payload.text || payload.message?.text || payload.message || '';\nconst phone = String(from).replace('@c.us','').replace('@s.whatsapp.net','').replace(/\\D/g,'');\nreturn [{ json: { session, from, phone, name: payload.notifyName || payload.pushName || payload.name || null, message, timestamp: payload.timestamp ? new Date(payload.timestamp * 1000).toISOString() : new Date().toISOString(), isGroup: String(from).includes('@g.us'), fromMe: Boolean(payload.fromMe), raw: body } }];"
      },
      "id": "normalize",
      "name": "Normalizar WAHA",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.isGroup}}",
              "value2": false
            },
            {
              "value1": "={{$json.fromMe}}",
              "value2": false
            }
          ],
          "string": [
            {
              "value1": "={{$json.message}}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "id": "if-valid",
      "name": "Ignorar grupos/fromMe/vazio",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        440,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.APP_URL}}/api/n8n/message/inbound",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.N8N_INTERNAL_TOKEN}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{JSON.stringify($json)}}",
        "options": {}
      },
      "id": "api-inbound",
      "name": "Registrar inbound",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        680,
        -120
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.APP_URL}}/api/n8n/ai/reply",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.N8N_INTERNAL_TOKEN}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{JSON.stringify({ ...$json, from: $('Normalizar WAHA').item.json.from })}}",
        "options": {}
      },
      "id": "api-ai",
      "name": "Gerar resposta IA",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        920,
        -120
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.needsHuman}}",
              "value2": true
            }
          ]
        }
      },
      "id": "if-human",
      "name": "Precisa humano?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1160,
        -120
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { ...$json, reply: 'Perfeito, vou chamar uma pessoa da equipe para continuar seu atendimento. Só um instante :)', leadStatus: 'aguardando_humano', humanPaused: true } }];"
      },
      "id": "human-message",
      "name": "Mensagem humano",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        -260
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.WAHA_BASE_URL}}/api/sendText",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "X-Api-Key",
              "value": "={{.WAHA_API_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{JSON.stringify({ session: $json.session || $json.tenant.wahaSessionName, chatId: $('Normalizar WAHA').item.json.from, text: $json.reply })}}",
        "options": {}
      },
      "id": "send-waha",
      "name": "Enviar via WAHA",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1640,
        -120
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.APP_URL}}/api/n8n/message/outbound",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.N8N_INTERNAL_TOKEN}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{JSON.stringify({ tenantId: $json.tenant.id, leadId: $json.lead.id, phone: $json.lead.phone, message: $json.reply, intent: $json.intent, needsHuman: $json.needsHuman, answeredByAi: true })}}",
        "options": {}
      },
      "id": "register-outbound",
      "name": "Registrar outbound",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1880,
